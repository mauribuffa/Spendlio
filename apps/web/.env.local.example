# Spendlio web — local env. Copy to .env.local.
# The API origin (NestJS HTTP server from apps/api), WITHOUT the /api prefix —
# the API client appends /api. Read server-side only; the dev x-user-id header
# never leaves the server.
API_URL=http://localhost:4000

# Dev auth: the web app talks to the API with this header (replaced by real
# auth in Phase 5). Must match a seeded user in the database (db:seed).
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
