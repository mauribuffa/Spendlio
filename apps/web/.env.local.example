# Spendlio web — local env. Copy to .env.local.
# The API origin (NestJS HTTP server from apps/api), WITHOUT the /api prefix —
# the API client appends /api. Read server-side only.
API_URL=http://localhost:4000

# Auth (Phase 5 — email OTP + Auth.js + short-lived JWT to the API; ADR-033).
AUTH_SECRET=change-me-dev-only        # Auth.js session secret
AUTH_URL=http://localhost:3000        # Auth.js base URL
API_JWT_SECRET=change-me-dev-only     # shared HS256 secret; MUST match apps/api

# Dev-login only: the seeded demo user the dev Credentials provider signs in as
# (db:seed). Not used by the real OTP path; has a built-in fallback if unset.
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
